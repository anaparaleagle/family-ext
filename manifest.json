{
  "manifest_version": 3,
  "name": "ParaLeagle Family myUSCIS Autofill",
  "version": "0.2.0",
  "description": "Autofill the guided online Forms I-130 and I-539 on myUSCIS from ParaLeagle family-visa data",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://my.uscis.gov/*",
    "https://family-api.paraleagle.io/*",
    "http://localhost:8001/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "background": {
    "service_worker": "download-proxy.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://my.uscis.gov/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://my.uscis.gov/*"],
      "js": ["formik-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
